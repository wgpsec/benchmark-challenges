doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    title Error
    style.
      body { font-family: sans-serif; text-align: center; padding: 50px; }
      h1 { color: #c00; }
      pre { background: #f5f5f5; padding: 20px; text-align: left; overflow-x: auto; }

  body
    h1 Error
    p= message
    if error
      pre= error
    p
      a(href="/") &larr; Back to Home
